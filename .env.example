# .env.example — шаблон переменных окружения для JadeBridge bot.
# Скопируй как credentials.env, заполни реальными значениями.
# Этот файл безопасно коммитить в Git — реальных секретов здесь нет.

# ───── Telegram ─────────────────────────────────
BOT_TOKEN=<telegram_bot_token>
TELEGRAM_TOKEN=<telegram_bot_token>
CHAT_ID=<your_telegram_user_id>
ALLOWED_USER_IDS=<user_id_1>,<user_id_2>

# ───── OpenRouter (LLM) ──────────────────────────
OPENROUTER_API_KEY=sk-or-v1-<key>

# ───── Голосовые сообщения (Groq Whisper) ─────────
GROQ_API_KEY=gsk_<key>

# ───── VPS Server ────────────────────────────────
VPS_HOST=<vps_ip>
VPS_USER=root
VPS_SSH_KEY_PATH=/home/<user>/.ssh/vps_jade_developer
VPS_PASSWORD=<vps_password>

# ───── Фаза 5: Топики супергруппы Jade_Developer ──
# ID супергруппы (отрицательное число, начинается с -100)
SUPERGROUP_ID=-1004295196278
# thread_id каждого топика (целое число — узнать через @userinfobot,
# переслав сообщение из нужного топика)
TOPIC_TEXTS_ID=<id>
TOPIC_TABLES_ID=<id>
TOPIC_IMAGES_ID=<id>
TOPIC_ARCHIVES_ID=<id>
TOPIC_ATTENTION_ID=<id>

# ───── News Pipeline ──────────────────────────────
NEWS_CHANNEL_ID=<channel_id>
NEWS_BOT_TOKEN=<telegram_bot_token>
NEWS_THREAD_ID=<thread_id>
CHANNEL_SIGNATURE=

# ───── TokenTracker ───────────────────────────────
TOKEN_ALERT_THRESHOLD=50000
TOKEN_ALERT_CHAT_ID=<chat_id>
TOKEN_ALERT_THREAD_ID=<thread_id>

# ───── Supabase (если используется) ──────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=<key>
SUPABASE_DB_PASSWORD=<password>
